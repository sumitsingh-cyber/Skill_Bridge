# Frontend Variables
VITE_RAZORPAY_KEY=your_razorpay_key
# For local frontend + backend development:
VITE_API_URL=http://localhost:4000/api/v1

# Backend Variables
PORT=4000
MONGODB_URL=your_mongodb_connection_string

# JWT
JWT_SECRET=your_jwt_secret

# Email Config
# Recommended production provider: Resend
RESEND_API_KEY=your_resend_api_key
MAIL_FROM=verify@your_verified_domain.com
MAIL_DEBUG=false

# SMTP fallback: Gmail example, development only
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your_email@gmail.com
# MAIL_PASS=your_16_character_gmail_app_password
# MAIL_FROM=your_email@gmail.com

# Brevo alternative:
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USER=your_brevo_login_email
# BREVO_SMTP_KEY=your_brevo_smtp_key
# MAIL_FROM=your_verified_sender_email

# Cloudinary Config
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret
FOLDER_NAME=your_cloudinary_folder

# Razorpay Config
RAZORPAY_KEY=your_razorpay_key
RAZORPAY_SECRET=your_razorpay_secret
